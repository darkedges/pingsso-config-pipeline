# PingFederate Configuration
pingfederate_base_url = "https://pingfederate.example.com"
pingfederate_username = "api-admin"
pingfederate_password = "CHANGEME"

# Security Settings
# Set to true ONLY for dev/test environments with self-signed certs
insecure_tls = false
